# Neon DB connection string from https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@ep-xxxx.us-east-2.aws.neon.tech/emg_db?sslmode=require

# Serial port where Arduino is connected
# Linux:   /dev/ttyUSB0  or  /dev/ttyACM0
# macOS:   /dev/tty.usbmodem...
# Windows: COM3
SERIAL_PORT=/dev/ttyUSB0

# Baud rate must match Arduino sketch (Serial.begin(9600))
BAUD_RATE=9600

# API server port (default 3000)
PORT=3000
