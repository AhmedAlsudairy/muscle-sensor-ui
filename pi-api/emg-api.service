[Unit]
Description=EMG Arduino API — Serial to Neon DB
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/muscle-sensor-ui/pi-api
ExecStart=/usr/bin/node /home/pi/muscle-sensor-ui/pi-api/server.js
Restart=always
RestartSec=5
ExecStartPre=/bin/sleep 5
EnvironmentFile=/home/pi/muscle-sensor-ui/pi-api/.env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=emg-api

[Install]
WantedBy=multi-user.target
